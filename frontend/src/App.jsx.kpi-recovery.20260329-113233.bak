function renderExecutiveDashboard({ accounts = [], contacts = [], opportunities = [] } = {}) {
  const safeAccounts = Array.isArray(accounts) ? accounts : [];
  const safeContacts = Array.isArray(contacts) ? contacts : [];
  const safeOpportunities = Array.isArray(opportunities) ? opportunities : [];

  function revenueFor(item) {
    const value = Number(
      item?.calculated_revenue ??
      item?.amount_total ??
      item?.calc_year1_total ??
      item?.amount_estimated ??
      0
    );
    return Number.isFinite(value) ? value : 0;
  }

  function weightedFor(item) {
    const explicitWeighted = Number(item?.weighted_revenue);
    if (Number.isFinite(explicitWeighted)) return explicitWeighted;

    const probability = Number(item?.probability ?? 0) / 100;
    return revenueFor(item) * (Number.isFinite(probability) ? probability : 0);
  }

  const openPipelineValue = safeOpportunities.reduce((sum, item) => sum + revenueFor(item), 0);
  const weightedPipelineValue = safeOpportunities.reduce((sum, item) => sum + weightedFor(item), 0);
  const totalPotentialMargin = safeOpportunities.reduce((sum, item) => {
    return sum + (revenueFor(item) * Number(item?.estimated_earnings_pct || 0) / 100);
  }, 0);

  const totalAccounts = safeAccounts.length;
  const totalContacts = safeContacts.length;
  const totalOpportunities = safeOpportunities.length;
  const avgDealSize = totalOpportunities ? openPipelineValue / totalOpportunities : 0;

  const staleCount = safeOpportunities.filter((item) => {
    const flag = String(item?.staleness_flag || '').toLowerCase();
    return flag.includes('risk') || flag.includes('overdue') || flag.includes('stale');
  }).length;

  function StatCard({ label, value, sub, tone = 'neutral' }) {
    const toneMap = {
      primary: { bg: '#E8F6F5', text: '#2EADA7' },
      accent: { bg: '#EAF2FB', text: '#4188CB' },
      success: { bg: '#EAF6EF', text: '#2F8F5B' },
      warning: { bg: '#FCEEE8', text: '#D7644B' },
      neutral: { bg: '#EDF2F1', text: '#667582' },
    };
    const palette = toneMap[tone] || toneMap.neutral;

    return (
      <div style={{ ...naesCardStyle(false), padding: '20px 22px' }}>
        <div style={{ width: '44px', height: '44px', borderRadius: '14px', background: palette.bg, display: 'flex', alignItems: 'center', justifyContent: 'center', color: palette.text, fontSize: '24px', fontWeight: 800 }}>
          •
        </div>
        <div style={{ marginTop: '14px', fontSize: '12px', fontWeight: 700, letterSpacing: '0.08em', textTransform: 'uppercase', color: '#6C7A86' }}>
          {label}
        </div>
        <div style={{ marginTop: '8px', fontSize: '18px', fontWeight: 800, color: palette.text }}>
          {value}
        </div>
        <div style={{ marginTop: '4px', fontSize: '13px', color: '#586674' }}>
          {sub}
        </div>
      </div>
    );
  }

  return (
    <div style={{ maxWidth: '1280px', margin: '0 auto', display: 'grid', gap: '24px' }}>
      <section style={{ ...naesCardStyle(true), padding: '26px 28px', background: 'linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%)' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', gap: '16px', alignItems: 'flex-start', flexWrap: 'wrap' }}>
          <div>
            {smallLabel('Executive Dashboard')}
            <h2 style={{ margin: '8px 0 0 0', fontSize: '38px', fontWeight: 800, color: naesTheme.text, letterSpacing: '-0.03em' }}>
              Executive Dashboard
            </h2>
            <p style={{ marginTop: '8px', fontSize: '15px', color: naesTheme.textMuted }}>
              Pipeline intelligence · Live CRM operating view
            </p>
          </div>

          <button
            type="button"
            style={{
              borderRadius: '18px',
              border: `1px solid ${naesTheme.border}`,
              background: '#fff',
              color: naesTheme.primaryStrong,
              padding: '12px 18px',
              fontSize: '14px',
              fontWeight: 700,
              cursor: 'default'
            }}
          >
            Executive Snapshot
          </button>
        </div>
      </section>

      <section style={{ display: 'grid', gridTemplateColumns: 'repeat(6, minmax(0, 1fr))', gap: '16px' }}>
        <StatCard label="Total Pipeline" value={formatCurrency(openPipelineValue)} sub={`${totalOpportunities} active deals`} tone="primary" />
        <StatCard label="Weighted Forecast" value={formatCurrency(weightedPipelineValue)} sub="forecast-adjusted" tone="success" />
        <StatCard label="Avg Deal Size" value={formatCurrency(avgDealSize)} sub="across active pipeline" tone="accent" />
        <StatCard label="Potential Margin" value={formatCurrency(totalPotentialMargin)} sub="estimated gross contribution" tone="success" />
        <StatCard label="Needs Attention" value={String(staleCount)} sub="stale / overdue" tone="warning" />
        <StatCard label="Active Accounts" value={String(totalAccounts)} sub={`${totalContacts} linked contacts`} tone="neutral" />
      </section>
    </div>
  );
}

