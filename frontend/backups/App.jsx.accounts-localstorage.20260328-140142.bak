function getInitialPath() {
  if (typeof window === 'undefined') return '/';
  return window.location.pathname || '/';
}

function parseOpportunityRoute(pathname) {
  if (!pathname) return { isOpportunities: false, detailId: null };

  if (pathname === '/opportunities') {
    return { isOpportunities: true, detailId: null };
  }

  const match = pathname.match(/^\/opportunities\/([^/]+)$/);
  if (match) {
    return { isOpportunities: true, detailId: match[1] };
  }

  return { isOpportunities: false, detailId: null };
}

function pushPath(path) {
  if (typeof window === 'undefined') return;
  window.history.pushState({}, '', path);
}

function replacePath(path) {
  if (typeof window === 'undefined') return;
  window.history.replaceState({}, '', path);
}

function OpportunitySummaryRow({ opportunity, onOpenOpportunity }) {
  const pills = buildOpportunityPills(opportunity).filter((pill) =>
    [
      'serviceLine',
      'marketSegment',
      'stage',
      'forecastCategory',
      'mwac',
      'mwdc',
      'followUpStatus',
      'forecastHygieneStatus',
      'expectedCloseDate'
    ].includes(pill.key)
  );

  const revenueValue = formatPillCurrency(opportunity.calculated_revenue) || '$0';
  const earningsPct = Number(opportunity.estimated_earnings_pct || 0);
  const weightedPct = opportunity.forecast_category === 'Commit'
    ? 0.9
    : opportunity.forecast_category === 'Best Case'
    ? 0.6
    : opportunity.forecast_category === 'Pipeline'
    ? 0.3
    : 0.5;

  const potentialMarginValue = formatPillCurrency((Number(opportunity.calculated_revenue || 0) * earningsPct) / 100) || '$0';
  const weightedValue = formatPillCurrency(Number(opportunity.calculated_revenue || 0) * weightedPct) || '$0';

  return (
    <button
      onClick={() => onOpenOpportunity(opportunity.id)}
      style={{
        width: '100%',
        border: '1px solid #E5ECE5',
        background: '#FFFFFF',
        borderRadius: '22px',
        padding: '18px 20px',
        textAlign: 'left',
        cursor: 'pointer',
        boxShadow: '0 8px 20px rgba(31,41,55,0.04)'
      }}
    >
      <div
        style={{
          display: 'grid',
          gridTemplateColumns: 'minmax(260px, 1.05fr) minmax(340px, 1.5fr) minmax(220px, 0.9fr)',
          gap: '18px',
          alignItems: 'start'
        }}
      >
        <div style={{ minWidth: 0 }}>
          <div style={{ fontSize: '20px', fontWeight: 700, color: '#111827' }}>
            {opportunity.name}
          </div>
          <div style={{ marginTop: '4px', fontSize: '14px', color: '#64748b' }}>
            {opportunity.account}
          </div>

          <div style={{ marginTop: '14px', display: 'grid', gap: '10px' }}>
            <div>
              <div style={{ fontSize: '10px', fontWeight: 700, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#64748b' }}>
                Owner
              </div>
              <div style={{ marginTop: '6px', fontSize: '14px', fontWeight: 600, color: '#111827' }}>
                {opportunity.owner_full_name}
              </div>
            </div>
          </div>
        </div>

        <div style={{ minWidth: 0 }}>
          <div
            style={{
              display: 'flex',
              flexWrap: 'wrap',
              gap: '8px',
              rowGap: '8px',
              alignItems: 'flex-start',
              minWidth: 0,
              maxWidth: '100%'
            }}
          >
            {pills.map((pill) => renderOpportunityPill(pill))}
          </div>
        </div>

        <div
          style={{
            borderRadius: '18px',
            border: '1px solid #D7E6DA',
            background: '#F7FBF8',
            padding: '14px 16px',
            display: 'grid',
            gap: '10px',
            minWidth: 0
          }}
        >
          <div>
            <div style={{ fontSize: '10px', fontWeight: 700, letterSpacing: '0.16em', textTransform: 'uppercase', color: '#64748b' }}>
              Revenue
            </div>
            <div style={{ marginTop: '6px', fontSize: '30px', fontWeight: 800, color: '#0B6771', lineHeight: 1.05 }}>
              {revenueValue}
            </div>
          </div>

          <div>
            <div style={{ fontSize: '10px', fontWeight: 700, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#64748b' }}>
              Potential Margin
            </div>
            <div style={{ marginTop: '4px', fontSize: '16px', fontWeight: 700, color: '#111827' }}>
              {potentialMarginValue}
            </div>
          </div>

          <div>
            <div style={{ fontSize: '10px', fontWeight: 700, letterSpacing: '0.14em', textTransform: 'uppercase', color: '#64748b' }}>
              Weighted Value
            </div>
            <div style={{ marginTop: '4px', fontSize: '16px', fontWeight: 700, color: '#111827' }}>
              {weightedValue}
            </div>
          </div>
        </div>
      </div>
    </button>
  );
}

